# Test environment variables — loaded automatically by tests/conftest.py.
# These override .env so that tests never touch production data or services.
# Do NOT commit real secrets to this file.

# ── EDGAR ─────────────────────────────────────────────────────────────────────
EDGAR_IDENTITY=test@example.com
EDGAR_LOCAL_DATA_DIR_RUNTIME=/tmp/ir_edgar_test_cache

# ── DuckDB ─────────────────────────────────────────────────────────────────────
# conftest.py creates a fresh per-session temp DuckDB and overrides
# DUCKDB_PATH_RUNTIME at startup, so the value below is a placeholder only.
# It must be a non-empty string to satisfy the config module's type annotation.
DUCKDB_PATH_RUNTIME=/tmp/ir_pytest_placeholder.duckdb

# ── SQLite state DB ────────────────────────────────────────────────────────────
# Tests that need a state DB create their own tmp files via tmp_path.
# This value is only a fallback if a test somehow reads the global default.
STATE_DB_PATH_RUNTIME=/tmp/ir_pytest_state.db

# ── LLM / chat ─────────────────────────────────────────────────────────────────
LLM_API_BASE=http://localhost:1234/v1
LLM_MODEL=test-model
