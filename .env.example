# SEC EDGAR identity (required — your name and email for User-Agent header)
EDGAR_IDENTITY=research@research.ai

# EDGAR data paths (host mount source vs runtime path)
# Host-side path for edgartools offline data; used as the Docker bind mount source (not read by the process).
EDGAR_LOCAL_DATA_DIR_HOST_SOURCE=/Path/To/Your/edgar-offline
# Runtime path the process reads/writes. For Docker this is overridden to /app/data/edgar.
# For local runs, set this to the same path as EDGAR_LOCAL_DATA_DIR_HOST_SOURCE.
EDGAR_LOCAL_DATA_DIR_RUNTIME=/Path/To/Your/edgar-offline

# DuckDB (directory-level mount + file reference)
DUCKDB_DIR_HOST_SOURCE=./data/duckdb
DUCKDB_DIR_RUNTIME=/app/data/duckdb
DUCKDB_PATH_HOST_SOURCE=./data/duckdb/financial_timeseries.duckdb
# Runtime DuckDB file path the process opens. For Docker this is overridden to /app/data/duckdb/financial_timeseries.duckdb.
DUCKDB_PATH_RUNTIME=./data/duckdb/financial_timeseries.duckdb

# SQLite state DB (directory-level mount + file reference)
STATE_DIR_HOST_SOURCE=./data/state
STATE_DIR_RUNTIME=/app/data/state
STATE_DB_PATH_HOST_SOURCE=./data/state/ingestion_state.db
# Runtime state DB path the process opens. For Docker this is overridden to /app/data/state/ingestion_state.db.
STATE_DB_PATH_RUNTIME=./data/state/ingestion_state.db

# Prefect API (optional)
PREFECT_API_URL=http://localhost:4200/api

# EDGAR filing download window & scope
# Download filings starting from this date (YYYY-MM-DD)
EDGAR_FILINGS_START_DATE=2026-03-19
# Raw SEC filing document storage ticker scope:
# - Unset or empty -> default top-10 tickers (AAPL NVDA UNH WMT XOM MSFT AMZN GOOGL META TSLA)
# - Set to ALL -> download raw filing documents for every company (large disk footprint)
# - Set to a comma-separated list -> only those tickers, e.g. AAPL,MSFT,GOOGL
# Bulk SEC metadata (submissions, companyfacts) is always downloaded for all companies.
#EDGAR_RAW_FILING_TICKERS=

# Financial Modeling Prep API key
FMP_API_KEY=your_fmp_api_key_here

# Force seed flow to run on startup even when data already exists.
# Set to true only when you want a full re-seed. Remove or set to false after.
FORCE_SEED=false
