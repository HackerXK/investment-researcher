# SEC EDGAR identity (required — your name and email for User-Agent header)
EDGAR_IDENTITY=research@research.ai

# Local storage directory for edgartools offline data
EDGAR_LOCAL_DATA_DIR=/Path/To/Your/edgar-offline

# Prefect API URL (for connecting to Prefect server)
PREFECT_API_URL=http://localhost:4200/api

# DuckDB database dir
DUCKDB_DIR=./data/duckdb

# DuckDB database path
DUCKDB_PATH=./data/duckdb/financial_timeseries.duckdb

# SQLite state database dir
STATE_DIR=./data/state

# SQLite state database path
STATE_DB_PATH=./data/state/ingestion_state.db

# Download filings starting from this date (YYYY-MM-DD)
EDGAR_FILINGS_START_DATE=2026-03-19

FMP_API_KEY=your_fmp_api_key_here
